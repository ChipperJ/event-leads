# Copy to .env.local and fill in values (never commit .env.local)
#
# If sign-in / onboarding fails locally:
# - Supabase → Authentication → URL Configuration: Site URL = http://localhost:3000
#   Add redirect: http://localhost:3000/auth/callback (and http://127.0.0.1:3000/auth/callback if needed)
# - Supabase → Authentication → Providers → Email: disable "Confirm email" for dev so sign-up logs you in immediately
# - Restart `npm run dev` after changing .env.local
#
# Supabase: in the dashboard, add Redirect URLs for magic link / OAuth / email confirm, e.g.
#   http://localhost:3000/auth/callback
#   https://your-production-domain/auth/callback
# (See README.md "Database setup" and DEVELOPER_HANDOFF.md.)

# Hosted project: Supabase Dashboard → Settings → API
# Local stack: install Docker, then `npm run supabase:start` and `npm run supabase:status` for URL + anon key
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional for future admin/service flows — current app uses anon key + user session only.
SUPABASE_SERVICE_ROLE_KEY=

# Text AI ("Extract insights", follow-up drafts): Claude (preferred if set) or OpenAI. Server-only.
# ANTHROPIC_API_KEY — https://console.anthropic.com/ (Claude Pro / claude.ai subscription does NOT include API access).
# Optional: ANTHROPIC_MODEL=claude-3-5-sonnet-20241022 (default if unset)
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=

# Voice transcription only: OpenAI Whisper (no Claude audio API). Optional if you only type/paste transcripts.
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Follow-up email/SMS (Session 9+) — server-side only
RESEND_API_KEY=
FROM_EMAIL=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
