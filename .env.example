# Copy to .env.local and fill in values (never commit .env.local)
#
# Supabase: in the dashboard, add Redirect URLs for magic link / OAuth / email confirm, e.g.
#   http://localhost:3000/auth/callback
#   https://your-production-domain/auth/callback
# (See README.md "Database setup" and DEVELOPER_HANDOFF.md.)

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional for future admin/service flows — current app uses anon key + user session only.
SUPABASE_SERVICE_ROLE_KEY=

OPENAI_API_KEY=

# Follow-up email/SMS (Session 9+) — server-side only
RESEND_API_KEY=
FROM_EMAIL=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
